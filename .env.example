# ── LLM provider selection ────────────────────────────────────────────────────
# Choose the backend for query understanding (intent / rewrite / HyDE):
#   none      → zero-key, $0, rule-based only (DEFAULT — safe for a public demo)
#   groq      → free API tier, fast (recommended free option)   key: GROQ_API_KEY
#   gemini    → free API tier                                   key: GOOGLE_API_KEY
#   openai    → paid                                            key: OPENAI_API_KEY
#   anthropic → paid                                            key: ANTHROPIC_API_KEY
LLM_PROVIDER=none
# Optional: override the model for the chosen provider (else a sensible default).
# LLM_MODEL=

# Provide ONLY the key for the provider you selected above:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# ── Gateway abuse protection ──────────────────────────────────────────────────
# Max /search requests per IP per minute (0 disables). Protects a public demo.
RATE_LIMIT_PER_MINUTE=60

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=search_ranking
POSTGRES_USER=searchuser
POSTGRES_PASSWORD=searchpass

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5001

# ── Service URLs (used by gateway to route internally) ─────────────────────────
QUERY_UNDERSTANDING_URL=http://query-understanding:8001
RETRIEVAL_URL=http://retrieval:8002
RANKING_URL=http://ranking:8003
FEEDBACK_URL=http://feedback:8004

# ── A/B Test Split (0.0 - 1.0, fraction routed to cross-encoder) ───────────────
AB_CROSSENCODER_FRACTION=0.5

# ── Retraining ─────────────────────────────────────────────────────────────────
RETRAINING_CLICK_THRESHOLD=1000
RETRAINING_NDCG_IMPROVEMENT=0.01
